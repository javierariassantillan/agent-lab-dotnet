@using SocOps.Models

<div class="flex flex-col min-h-full bg-slate-50">
    <header class="flex flex-col gap-3 p-4 bg-white border-b border-slate-200 shadow-sm md:flex-row md:items-center md:justify-between">
        <div>
            <p class="text-sm uppercase tracking-[0.35em] text-blue-700 mb-2">Team bingo</p>
            <h1 class="text-2xl font-semibold text-slate-900">Soc Ops</h1>
        </div>

        <button
            @onclick="OnReset"
            class="rounded-2xl border border-slate-200 px-4 py-2 text-sm text-slate-700 active:bg-slate-100 transition-colors duration-200">
            ← Regresar
        </button>
    </header>

    <div class="px-4 py-4">
        <p class="text-center text-slate-600 text-sm max-w-2xl mx-auto">Toca una casilla cuando encuentres a alguien que coincida con la pregunta. Mantén el ritmo y busca una línea completa para lograr bingo.</p>
    </div>

    @if (HasBingo)
    {
        <div class="mx-4 mb-4 rounded-2xl border border-blue-200 bg-blue-50 text-blue-800 text-center py-3 px-4 font-semibold text-sm shadow-sm">
            🎉 BINGO! Has completado una línea.
        </div>
    }

    <div class="flex-1 flex items-center justify-center px-4 pb-6">
        <div class="w-full max-w-3xl bg-white border border-slate-200 rounded-[32px] shadow-card p-5">
            <BingoBoard
                Board="@Board"
                WinningSquareIds="@WinningSquareIds"
                OnSquareClick="@OnSquareClick" />
        </div>
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
