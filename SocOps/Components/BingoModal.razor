<div class="fixed inset-0 bg-black/50 flex items-center justify-center p-4 z-50">
    <div class="bg-white rounded-[32px] p-8 max-w-sm w-full text-center shadow-xl animate-[bounce_0.5s_ease-out]">
        <div class="mx-auto mb-5 flex h-20 w-20 items-center justify-center rounded-full bg-blue-50 text-blue-700 text-4xl">✓</div>
        <h2 class="text-3xl font-semibold text-slate-900 mb-2">BINGO!</h2>
        <p class="text-sm text-slate-600 mb-6">Has completado una línea con estilo. Continúa y sigue marcando.</p>

        <button
            @onclick="OnDismiss"
            class="w-full bg-accent text-white font-semibold py-3 rounded-2xl shadow-sm active:bg-accent-dark transition-colors duration-200">
            Continuar
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
