@using SocOps.Models

<button
    @onclick="OnClick"
    disabled="@Square.IsFreeSpace"
    class="@GetCssClasses()"
    aria-pressed="@Square.IsMarked"
    aria-label="@(Square.IsFreeSpace ? "Free space" : Square.Text)">
    <span class="wrap-break-word hyphens-auto">@Square.Text</span>
    @if (Square.IsMarked && !Square.IsFreeSpace)
    {
        <span class="absolute top-0.5 right-0.5 text-blue-800 text-xs">✓</span>
    }
</button>

@code {
    [Parameter]
    public BingoSquareData Square { get; set; } = null!;

    [Parameter]
    public bool IsWinning { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string GetCssClasses()
    {
        var baseClasses = "relative flex items-center justify-center p-1 text-center border border-slate-200 rounded-xl transition-all duration-150 select-none min-h-[60px] text-xs leading-tight bg-white text-slate-700";

        var stateClasses = Square.IsMarked
            ? IsWinning
                ? "bg-blue-100 border-blue-200 text-blue-900 shadow-sm"
                : "bg-blue-50 border-blue-200 text-blue-800 shadow-sm"
            : "bg-white text-slate-700 active:bg-slate-100";

        var freeSpaceClasses = Square.IsFreeSpace ? "font-semibold text-sm bg-slate-100 border-slate-200" : "";

        return $"{baseClasses} {stateClasses} {freeSpaceClasses}";
    }
}
