<div class="min-h-full bg-slate-50 flex items-center justify-center p-6">
    <div class="max-w-2xl w-full">
        <div class="bg-white border border-slate-200 rounded-[32px] shadow-card p-8">
            <div class="text-center mb-10">
                <p class="text-sm uppercase tracking-[0.35em] text-blue-700 mb-4">Social icebreaker</p>
                <h1 class="text-5xl font-semibold text-slate-900 mb-4">Soc Ops</h1>
                <p class="text-base text-slate-600 max-w-2xl mx-auto">Un tablero de bingo social con estilo corporativo para reuniones y equipos. Marca una casilla cuando encuentres coincidencias y consigue una línea para ganar.</p>
            </div>

            <div class="bg-slate-50 border border-slate-200 rounded-3xl p-6 mb-8">
                <h2 class="text-lg font-semibold text-slate-900 mb-4">Cómo jugar</h2>
                <ul class="space-y-3 text-slate-600 text-sm text-left">
                    <li>• Encuentra personas que cumplan las preguntas.</li>
                    <li>• Toca una casilla para marcarla.</li>
                    <li>• Completa 5 en línea para obtener bingo.</li>
                </ul>
            </div>

            <button
                @onclick="OnStart"
                class="w-full bg-accent text-white font-semibold py-4 px-8 rounded-2xl text-lg shadow-sm active:bg-accent-dark transition-colors duration-200">
                Iniciar juego
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
